        </mxCell>
        <mxCell id="e_data_end_no" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="data_reject" target="end_no">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Approve Path -->
        <!-- Manual Input -->
