        </mxCell>
        <mxCell id="e_eval_dec" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="process_eval" target="dec_approv">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Reject Path -->
        <!-- Processing -->
        <mxCell id="process_reject" value="Keterangan Penolakan" style="rounded=0;whiteSpace=wrap;html=1;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="100" y="440" width="140" height="60" as="geometry" />
        </mxCell>
        <mxCell id="e_dec_reject" value="Tidak" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;entryX=1;entryY=0.5;fontStyle=1" edge="1" parent="1" source="dec_approv" target="process_reject">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Data Input/Output (Hit API to save) -->
        <mxCell id="data_reject" value="Update Status Sistem:&#10;Rejected/Cancelled" style="shape=parallelogram;perimeter=parallelogramPerimeter;whiteSpace=wrap;html=1;fixedSize=1;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="90" y="560" width="160" height="60" as="geometry" />
        </mxCell>
        <mxCell id="e_reject_data" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="process_reject" target="data_reject">
          <mxGeometry relative="1" as="geometry" />
