        </mxCell>
        <mxCell id="e_dec_input" value="Ya" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;entryX=0.5;entryY=0.15;fontStyle=1" edge="1" parent="1" source="dec_approv" target="input_approve">
