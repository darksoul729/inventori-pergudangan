        <mxCell id="e_doc_eval" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.5;exitY=0.875;exitPerimeter=0;entryX=0.5;entryY=0;" edge="1" parent="1" source="doc_in" target="process_eval">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        
        <!-- Decision -->
        <mxCell id="dec_approv" value="Apakah PO&#10;Disetujui?" style="rhombus;whiteSpace=wrap;html=1;strokeWidth=2;" vertex="1" parent="1">
