        <!-- Data Input/Output -->
        <mxCell id="data_approve" value="Update Status Sistem:&#10;Approved &amp;&#10;Catat Manager ID" style="shape=parallelogram;perimeter=parallelogramPerimeter;whiteSpace=wrap;html=1;fixedSize=1;strokeWidth=2;" vertex="1" parent="1">
