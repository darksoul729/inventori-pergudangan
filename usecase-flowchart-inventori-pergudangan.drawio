  <diagram id="flowchart-buat-akun" name="2. Flowchart Pembuatan Akun">
    <mxGraphModel dx="1200" dy="900" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="0" pageScale="1" pageWidth="900" pageHeight="1650" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- ===== TITLE ===== -->
        <mxCell id="fc-title-bg" parent="1" value="" vertex="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1a237e;strokeColor=#1a237e;arcSize=3;">
          <mxGeometry x="80" y="20" width="700" height="50" as="geometry" />
        </mxCell>
        <mxCell id="fc-title-txt" parent="1" value="FLOWCHART — Pembuatan Akun Operasional (Supervisor / Staff)" vertex="1" style="text;html=1;align=center;fontColor=#ffffff;fontSize=14;fontStyle=1;">
          <mxGeometry x="80" y="24" width="700" height="28" as="geometry" />
        </mxCell>
        <mxCell id="fc-sub-txt" parent="1" value="Aktor: Manager  |  Modul: Settings → Akun Operasional" vertex="1" style="text;html=1;align=center;fontColor=#90caf9;fontSize=10;">
          <mxGeometry x="80" y="50" width="700" height="18" as="geometry" />
        </mxCell>

        <!-- ===== LEGENDA SIMBOL ===== -->
        <mxCell id="leg-box" parent="1" value="" vertex="1" style="rounded=1;fillColor=#fafafa;strokeColor=#b0bec5;strokeWidth=1;">
          <mxGeometry x="620" y="90" width="215" height="220" as="geometry" />
        </mxCell>
        <mxCell id="leg-hdr" parent="1" value="LEGENDA SIMBOL" vertex="1" style="text;html=1;align=center;fontStyle=1;fontSize=10;fontColor=#263238;">
          <mxGeometry x="620" y="93" width="215" height="16" as="geometry" />
        </mxCell>
        <!-- terminator -->
        <mxCell id="leg-term-shape" parent="1" value="Terminator&#xa;(Mulai/Selesai)" vertex="1" style="shape=mxgraph.flowchart.terminator;fillColor=#c5cae9;strokeColor=#1a237e;fontSize=9;fontColor=#1a237e;">
          <mxGeometry x="630" y="112" width="90" height="28" as="geometry" />
        </mxCell>
        <!-- process -->
        <mxCell id="leg-proc-shape" parent="1" value="Process&#xa;(Langkah Otomatis)" vertex="1" style="shape=mxgraph.flowchart.process;fillColor=#bbdefb;strokeColor=#0d47a1;fontSize=9;fontColor=#0d47a1;">
          <mxGeometry x="630" y="148" width="90" height="28" as="geometry" />
        </mxCell>
        <!-- manual input -->
        <mxCell id="leg-input-shape" parent="1" value="Manual Input&#xa;(Input keyboard)" vertex="1" style="shape=mxgraph.flowchart.manual_input;fillColor=#fff3e0;strokeColor=#e65100;fontSize=9;fontColor=#e65100;">
          <mxGeometry x="630" y="184" width="90" height="28" as="geometry" />
        </mxCell>
        <!-- manual operation -->
        <mxCell id="leg-manop-shape" parent="1" value="Manual Operation&#xa;(Aksi oleh user)" vertex="1" style="shape=mxgraph.flowchart.manual_operation;fillColor=#e3f2fd;strokeColor=#0d47a1;fontSize=9;fontColor=#0d47a1;">
          <mxGeometry x="630" y="220" width="90" height="28" as="geometry" />
        </mxCell>
        <!-- decision -->
        <mxCell id="leg-dec-shape" parent="1" value="Decision&#xa;(Kondisi/Pilihan)" vertex="1" style="rhombus;fillColor=#fff9c4;strokeColor=#f9a825;fontSize=9;fontColor=#795548;">
          <mxGeometry x="630" y="256" width="90" height="40" as="geometry" />
        </mxCell>
        <!-- labels beside shapes -->
        <mxCell id="leg-note" parent="1" value="⬭ Oval = Mulai/Selesai&#xa;▭ Kotak = Proses komputer&#xa;▱ Miring = Input keyboard&#xa;⌂ Trapesium = Aksi manual&#xa;◇ Diamond = Keputusan" vertex="1" style="text;html=1;fontSize=9;fontColor=#455a64;align=left;verticalAlign=top;">
          <mxGeometry x="728" y="112" width="100" height="100" as="geometry" />
        </mxCell>

        <!-- ===== 1. TERMINATOR: MULAI ===== -->
        <mxCell id="fc-start" parent="1" value="MULAI" vertex="1" style="shape=mxgraph.flowchart.terminator;fillColor=#1a237e;strokeColor=#1a237e;fontColor=#ffffff;fontSize=13;fontStyle=1;">
          <mxGeometry x="325" y="90" width="150" height="50" as="geometry" />
        </mxCell>

        <!-- ===== 2. PROCESS: Manager login ===== -->
        <mxCell id="fc-s1" parent="1" value="Manager login ke sistem" vertex="1" style="shape=mxgraph.flowchart.process;fillColor=#bbdefb;strokeColor=#0d47a1;fontSize=11;fontColor=#0d47a1;">
          <mxGeometry x="275" y="185" width="250" height="50" as="geometry" />
        </mxCell>

        <!-- ===== 3. PROCESS: Buka Settings ===== -->
        <mxCell id="fc-s2" parent="1" value="Buka Settings → Tab Akun Operasional" vertex="1" style="shape=mxgraph.flowchart.process;fillColor=#bbdefb;strokeColor=#0d47a1;fontSize=11;fontColor=#0d47a1;">
          <mxGeometry x="275" y="280" width="250" height="50" as="geometry" />
        </mxCell>

        <!-- ===== 4. MANUAL OPERATION: Klik Buat Akun ===== -->
        <mxCell id="fc-s3" parent="1" value='Klik tombol "Buat Akun Baru"' vertex="1" style="shape=mxgraph.flowchart.manual_operation;fillColor=#e3f2fd;strokeColor=#1565c0;fontSize=11;fontColor=#1565c0;">
          <mxGeometry x="275" y="375" width="250" height="50" as="geometry" />
        </mxCell>

        <!-- ===== 5. MANUAL INPUT: Isi Form ===== -->
        <mxCell id="fc-s4" parent="1" value="Isi form:&#xa;• Nama (wajib, maks 100 karakter)&#xa;• Email (wajib, harus unik)&#xa;• No. Telepon (opsional)&#xa;• Role: Supervisor / Staff&#xa;• Password + Konfirmasi Password" vertex="1" style="shape=mxgraph.flowchart.manual_input;fillColor=#fff3e0;strokeColor=#e65100;fontSize=10;fontColor=#bf360c;align=left;">
          <mxGeometry x="250" y="470" width="300" height="110" as="geometry" />
        </mxCell>

        <!-- ===== 6. MANUAL OPERATION: Klik Simpan ===== -->
        <mxCell id="fc-s5" parent="1" value="Klik Simpan / Submit" vertex="1" style="shape=mxgraph.flowchart.manual_operation;fillColor=#e3f2fd;strokeColor=#1565c0;fontSize=11;fontColor=#1565c0;">
          <mxGeometry x="275" y="625" width="250" height="50" as="geometry" />
        </mxCell>

        <!-- ===== 7. DECISION: Validasi berhasil? ===== -->
        <mxCell id="fc-d1" parent="1" value="Validasi input&#xa;berhasil?" vertex="1" style="rhombus;fillColor=#fff9c4;strokeColor=#f9a825;fontSize=11;fontStyle=1;fontColor=#5d4037;">
          <mxGeometry x="300" y="715" width="200" height="90" as="geometry" />
        </mxCell>

        <!-- Error 1: Validasi gagal -->
        <mxCell id="fc-err1" parent="1" value="Tampilkan pesan error&#xa;validasi pada form" vertex="1" style="shape=mxgraph.flowchart.process;fillColor=#ffebee;strokeColor=#c62828;fontSize=10;fontColor=#c62828;">
          <mxGeometry x="590" y="733" width="185" height="50" as="geometry" />
        </mxCell>
        <mxCell id="lbl-gagal" parent="1" value="GAGAL" vertex="1" style="text;html=1;fontSize=9;fontColor=#c62828;fontStyle=1;align=center;">
          <mxGeometry x="507" y="740" width="80" height="18" as="geometry" />
        </mxCell>

        <!-- ===== 8. DECISION: Email terdaftar? ===== -->
        <mxCell id="fc-d2" parent="1" value="Email sudah&#xa;terdaftar?" vertex="1" style="rhombus;fillColor=#fff9c4;strokeColor=#f9a825;fontSize=11;fontStyle=1;fontColor=#5d4037;">
          <mxGeometry x="300" y="850" width="200" height="90" as="geometry" />
        </mxCell>

        <!-- Error 2: Email duplikat -->
        <mxCell id="fc-err2" parent="1" value='Error: "Email sudah&#xa;digunakan"' vertex="1" style="shape=mxgraph.flowchart.process;fillColor=#ffebee;strokeColor=#c62828;fontSize=10;fontColor=#c62828;">
          <mxGeometry x="590" y="868" width="185" height="50" as="geometry" />
        </mxCell>
        <mxCell id="lbl-dup" parent="1" value="YA" vertex="1" style="text;html=1;fontSize=9;fontColor=#c62828;fontStyle=1;align=center;">
          <mxGeometry x="507" y="875" width="80" height="18" as="geometry" />
        </mxCell>

        <!-- ===== 9. PROCESS: Ambil role_id ===== -->
        <mxCell id="fc-s6" parent="1" value="Ambil role_id dari tabel roles&#xa;sesuai nama (Supervisor / Staff)" vertex="1" style="shape=mxgraph.flowchart.process;fillColor=#e8f5e9;strokeColor=#2e7d32;fontSize=10;fontColor=#1b5e20;">
          <mxGeometry x="262" y="985" width="276" height="50" as="geometry" />
        </mxCell>

        <!-- ===== 10. PROCESS: Simpan user ke DB ===== -->
        <mxCell id="fc-s7" parent="1" value="Simpan user baru ke tabel users:&#xa;• role_id (sesuai pilihan)&#xa;• name, email, phone&#xa;• password → bcrypt hash&#xa;• email_verified_at = now()&#xa;• status = 'active'" vertex="1" style="shape=mxgraph.flowchart.process;fillColor=#e8f5e9;strokeColor=#2e7d32;fontSize=10;fontColor=#1b5e20;align=left;">
          <mxGeometry x="250" y="1080" width="300" height="110" as="geometry" />
        </mxCell>

        <!-- ===== 11. PROCESS: Redirect ===== -->
        <mxCell id="fc-s8" parent="1" value="Redirect → Settings Tab Akun Operasional" vertex="1" style="shape=mxgraph.flowchart.process;fillColor=#bbdefb;strokeColor=#0d47a1;fontSize=11;fontColor=#0d47a1;">
          <mxGeometry x="262" y="1235" width="276" height="50" as="geometry" />
        </mxCell>

        <!-- ===== 12. PROCESS: Notifikasi sukses ===== -->
        <mxCell id="fc-s9" parent="1" value='Tampil notifikasi:&#xa;"Akun operasional berhasil dibuat"' vertex="1" style="shape=mxgraph.flowchart.process;fillColor=#f3e5f5;strokeColor=#6a1b9a;fontSize=10;fontColor=#6a1b9a;">
          <mxGeometry x="262" y="1330" width="276" height="50" as="geometry" />
        </mxCell>

        <!-- ===== 13. PROCESS: Akun aktif ===== -->
        <mxCell id="fc-s10" parent="1" value="Akun aktif — siap digunakan untuk login" vertex="1" style="shape=mxgraph.flowchart.process;fillColor=#e8f5e9;strokeColor=#2e7d32;fontSize=11;fontStyle=1;fontColor=#1b5e20;">
          <mxGeometry x="262" y="1430" width="276" height="50" as="geometry" />
        </mxCell>

        <!-- ===== 14. TERMINATOR: SELESAI ===== -->
        <mxCell id="fc-end" parent="1" value="SELESAI" vertex="1" style="shape=mxgraph.flowchart.terminator;fillColor=#1a237e;strokeColor=#1a237e;fontColor=#ffffff;fontSize=13;fontStyle=1;">
          <mxGeometry x="325" y="1530" width="150" height="50" as="geometry" />
        </mxCell>

        <!-- ============================= -->
        <!-- PANAH HAPPY PATH (vertical)  -->
        <!-- ============================= -->
        <mxCell id="e-start-s1" edge="1" parent="1" source="fc-start" target="fc-s1" style="endArrow=block;endFill=1;strokeColor=#1a237e;strokeWidth=2;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e-s1-s2" edge="1" parent="1" source="fc-s1" target="fc-s2" style="endArrow=block;endFill=1;strokeColor=#0d47a1;strokeWidth=1.5;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e-s2-s3" edge="1" parent="1" source="fc-s2" target="fc-s3" style="endArrow=block;endFill=1;strokeColor=#0d47a1;strokeWidth=1.5;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e-s3-s4" edge="1" parent="1" source="fc-s3" target="fc-s4" style="endArrow=block;endFill=1;strokeColor=#e65100;strokeWidth=1.5;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e-s4-s5" edge="1" parent="1" source="fc-s4" target="fc-s5" style="endArrow=block;endFill=1;strokeColor=#0d47a1;strokeWidth=1.5;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e-s5-d1" edge="1" parent="1" source="fc-s5" target="fc-d1" style="endArrow=block;endFill=1;strokeColor=#f9a825;strokeWidth=1.5;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Decision 1 → GAGAL (kanan) -->
        <mxCell id="e-d1-err1" edge="1" parent="1" source="fc-d1" target="fc-err1" style="endArrow=block;endFill=1;strokeColor=#c62828;strokeWidth=1.5;exitX=1;exitY=0.5;entryX=0;entryY=0.5;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
